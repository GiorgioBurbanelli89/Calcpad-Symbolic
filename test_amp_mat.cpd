"Test & 1 en operaciones matriciales

E = 200000 MPa
t = 0.2 m
L = 1 m

D = E*t*[1; 0.2|0.2; 1]
B = [1/L; 0; -1/L|0; 1/L; 0]

"1. BtDB directo (falla por unidades mixtas)
'BtDB_d = transp(B)*D*B (da error inconsistent units)

"2. BtDB con & 1 (adimensional SI base)
BtDB_1 = transp(B)*D*B & 1
BtDB_1

"3. BtDB con & kN/m (re-estampa)
BtDB_u = transp(B)*D*B & kN/m
BtDB_u

"4. Acumular en K con & 1
K = symmetric(3)
K_add = transp(B)*D*B & 1
#for i = 1 : 3
	#for j = i : 3
		K.(i; j) = K.(i; j) + K_add.(i; j)
	#loop
#loop
K

"5. F y solve con & 1
F = [10000; -5000; 3000]
u = lsolve(K; F)
u

"6. Con unidades completas y & al final
F_u = [10 kN; -5 kN; 3 kN]
u_u = lsolve(K; F_u) & [mm; mm; mm]
u_u
