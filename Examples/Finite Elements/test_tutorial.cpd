"Test — Portal Frame Simple
'<hr/>

E = 200000
A_c = 0.09
I_c = 6.75*10^(-4)
L_c = 4
A_v = 0.15
I_v = 3.125*10^(-3)
L_v = 6

'Componentes columna vertical:
k2 = 12*E*I_c/L_c^3
k3 = 6*E*I_c/L_c^2
k4 = 4*E*I_c/L_c
k5 = 2*E*I_c/L_c
ea = E*A_c/L_c

'Componentes viga:
v1 = E*A_v/L_v
v2 = 12*E*I_v/L_v^3
v3 = 6*E*I_v/L_v^2
v4 = 4*E*I_v/L_v
v5 = 2*E*I_v/L_v

'K_ff (6x6): nodo 3 (col1 top + viga left) y nodo 4 (col2 top + viga right)
Kff = [k2+v1; 0; -k3+0; -v1; 0; 0 | 0; ea+v2; 0+v3; 0; -v2; v3 | -k3+0; 0+v3; k4+v4; 0; -v3; v5 | -v1; 0; 0; k2+v1; 0; k3 | 0; -v2; -v3; 0; ea+v2; -v3 | 0; v3; v5; k3; -v3; k4+v4]

F_f = [10; 0; 0; 0; 0; 0]
u_f = lsolve(Kff; F_f)

u_3x = u_f.(1)
u_3y = u_f.(2)
θ_3 = u_f.(3)
u_4x = u_f.(4)
u_4y = u_f.(5)
θ_4 = u_f.(6)

"Visualization
#hide
nod = [0; 0 | 6; 0 | 0; 4 | 6; 4]
ele = [1; 3 | 2; 4 | 3; 4]
sop = [1; 2]
dsp = [0; 0 | 0; 0 | u_3x; u_3y | u_4x; u_4y]
'Momentos simplificados
M1i = k3*u_3x + k5*θ_3
M1j = k3*u_3x + k4*θ_3
M2i = -k3*u_4x + k5*θ_4
M2j = -k3*u_4x + k4*θ_4
Mvi = v3*u_3y + v4*θ_3 - v3*u_4y + v5*θ_4
Mvj = v3*u_3y + v5*θ_3 - v3*u_4y + v4*θ_4
moms = [M1i; M1j | M2i; M2j | Mvi; Mvj]
#show

$Frame{nod; ele; sop; dsp; moms @ defScale=10 : diagScale=0.05 : title=Portal Frame}
