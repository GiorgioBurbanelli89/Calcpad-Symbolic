"Placa Base e50 - DKQ Shell-Thin (malla irregular = SAP2000)

"1. Datos (sistema N-mm)
E_a = 200000','ν = 0.3','t_a = 50
P_a = 1480000
n_dof = 3

"2. Malla irregular 9x9
#hide
x_ax = [0; 50; 100; 175; 250; 325; 400; 450; 500]
y_ax = [0; 50; 112; 174; 300; 426; 488; 550; 600]
n_j = 81','n_e = 64','n_total = n_dof*n_j','n_1 = 9
x_j = vector(n_j)','y_j = vector(n_j)
k = 0
#for j = 1 : 9
	#for i = 1 : 9
		k = k + 1','x_j.k = x_ax.i','y_j.k = y_ax.j
	#loop
#loop
e_j = matrix(n_e; 4)
#for j = 0 : 7
	#for i = 0 : 7
		e = j*8 + i + 1','bl = j*9 + i + 1
		e_j.(e; 1) = bl','e_j.(e; 2) = bl + 1
		e_j.(e; 3) = bl + 10','e_j.(e; 4) = bl + 9
	#loop
#loop

"3. DKQ
D_b = E_a*t_a^3/(12*(1 - ν^2))*[1; ν; 0|ν; 1; 0|0; 0; (1 - ν)/2]
g = 1/sqr(3)','n_k = 12
K = symmetric(n_total)
#for e = 1 : n_e
	i1 = e_j.(e; 1)','i3 = e_j.(e; 3)
	dx = x_j.i3 - x_j.i1','dy = y_j.i3 - y_j.i1
	dJ = dx*dy/4
	K_e = symmetric(n_k)
	#for ig = 1 : 4
		#if ig ≡ 1
			ξ = -g','η = -g
		#else if ig ≡ 2
			ξ = g','η = -g
		#else if ig ≡ 3
			ξ = g','η = g
		#else
			ξ = -g','η = g
		#end if
		Rx_w1 = 3*ξ*(1 - η)/dx^2
		Rx_t1 = (1 - η)*(3*ξ - 1)/(2*dx)
		Rx_w2 = -3*ξ*(1 - η)/dx^2
		Rx_t2 = (1 - η)*(1 + 3*ξ)/(2*dx)
		Rx_w3 = -3*ξ*(1 + η)/dx^2
		Rx_t3 = (1 + η)*(1 + 3*ξ)/(2*dx)
		Rx_w4 = 3*ξ*(1 + η)/dx^2
		Rx_t4 = (1 + η)*(3*ξ - 1)/(2*dx)
		Ry_w1 = 3*(1 - ξ)*η/dy^2
		Ry_t1 = (1 - ξ)*(3*η - 1)/(2*dy)
		Ry_w2 = 3*(1 + ξ)*η/dy^2
		Ry_t2 = (1 + ξ)*(3*η - 1)/(2*dy)
		Ry_w3 = -3*(1 + ξ)*η/dy^2
		Ry_t3 = (1 + ξ)*(1 + 3*η)/(2*dy)
		Ry_w4 = -3*(1 - ξ)*η/dy^2
		Ry_t4 = (1 - ξ)*(1 + 3*η)/(2*dy)
		TT = 3*(2 - ξ^2 - η^2)/(2*dx*dy)
		Rxy_bx1 = (1 - ξ)*(1 + 3*ξ)/(4*dy)
		Rxy_by1 = (1 - η)*(1 + 3*η)/(4*dx)
		Rxy_bx2 = (1 + ξ)*(1 - 3*ξ)/(4*dy)
		Rxy_by2 = -(1 - η)*(1 + 3*η)/(4*dx)
		Rxy_bx3 = (1 + ξ)*(3*ξ - 1)/(4*dy)
		Rxy_by3 = (1 + η)*(3*η - 1)/(4*dx)
		Rxy_bx4 = -(1 - ξ)*(1 + 3*ξ)/(4*dy)
		Rxy_by4 = (1 + η)*(1 - 3*η)/(4*dx)
		Bb = [ _
		Rx_w1; 0; Rx_t1; Rx_w2; 0; Rx_t2; Rx_w3; 0; Rx_t3; Rx_w4; 0; Rx_t4 | _
		Ry_w1; -Ry_t1; 0; Ry_w2; -Ry_t2; 0; Ry_w3; -Ry_t3; 0; Ry_w4; -Ry_t4; 0 | _
		TT; -Rxy_by1; Rxy_bx1; -TT; -Rxy_by2; Rxy_bx2; TT; -Rxy_by3; Rxy_bx3; -TT; -Rxy_by4; Rxy_bx4]
		BtDB = transp(Bb)*D_b*Bb*dJ
		#for i = 1 : n_k
			#for j = i : n_k
				K_e.(i; j) = K_e.(i; j) + BtDB.(i; j)
			#loop
		#loop
	#loop
	#for i = 1 : 4
		#for j = i : 4
			j1 = e_j.(e; i)','j2 = e_j.(e; j)
			i1 = n_dof*(j1 - 1) + 1','i2 = n_dof*(j2 - 1) + 1
			kij = submatrix(K_e; n_dof*(i - 1) + 1; n_dof*i; n_dof*(j - 1) + 1; n_dof*j)
			#if j1 > j2
				add(transp(kij); K; i2; i1)
			#else
				add(kij; K; i1; i2)
			#end if
		#loop
	#loop
#loop

"4. Springs (tributarias, identicas a SAP2000)
k_w = 50000
#for j = 1 : 9
	#for i = 1 : 9
		k = (j - 1)*9 + i
		x0 = x_ax.(max(i - 1; 1))','x1 = x_ax.i','x2 = x_ax.(min(i + 1; 9))
		y0 = y_ax.(max(j - 1; 1))','y1 = y_ax.j','y2 = y_ax.(min(j + 1; 9))
		tx = (x1 - x0)/2 + (x2 - x1)/2','ty = (y1 - y0)/2 + (y2 - y1)/2
		kn = k_w*tx*ty/10^6
		K.(n_dof*(k - 1) + 1; n_dof*(k - 1) + 1) = K.(n_dof*(k - 1) + 1; n_dof*(k - 1) + 1) + kn
	#loop
#loop
'Bolts en (50,50)→n11, (450,50)→n17, (50,550)→n65, (450,550)→n71
k_bolt = 200000*3.14159*(25.4/2)^2/500
bolt_nodes = [11; 17; 65; 71]
#for p = 1 : 4
	k = bolt_nodes.p
	K.(n_dof*(k - 1) + 1; n_dof*(k - 1) + 1) = K.(n_dof*(k - 1) + 1; n_dof*(k - 1) + 1) + k_bolt
#loop

"5. Carga
F = vector(n_total)
jc = 41
F.(n_dof*(jc - 1) + 1) = -P_a
#show

"6. Solucion
Z = clsolve(K; F)

"7. Resultados
w_c = Z.(n_dof*(jc - 1) + 1)*(1 mm)
'Deflexion centro DKQ Shell-Thin:
w_c
w_c | mm
'SAP2000 Shell-Thin (misma malla): -6.0569 mm
'Python DKQ (misma malla): -6.0580 mm
'Ratio:
w_c/(-6.0569 mm)
