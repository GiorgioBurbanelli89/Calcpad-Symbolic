"Test & en acumulacion de K_e

E = 200000 MPa
t = 0.2 m
L = 1 m
ν = 0.2

D = E*t/(1 - ν^2)*[1; ν; 0|ν; 1; 0|0; 0; (1 - ν)/2]
B = [1/L; 0; -1/L|0; 1/L; 0|1/L; 1/L; -1/L]

'BtDB con & directo:
BtDB = transp(B)*D*B*(L^2/4) & [kN/m; kN/m; kN/m|kN/m; kN/m; kN/m|kN/m; kN/m; kN/m]
BtDB

'Acumular en K (adimensional):
K = symmetric(3)
#for i = 1 : 3
	#for j = i : 3
		K.(i; j) = K.(i; j) + BtDB.(i; j)
	#loop
#loop
K

'F con unidades:
F = [10 kN; -5 kN; 3 kN]

'Solve con &:
u = lsolve(K; F) & [mm; mm; mm]
u
