"Test calcpad-viz: $Fem2D, $Fem3D, $Chart
'<h3>Malla 2D con resultados</h3>
#hide
'Crear malla 3x2
n_a = 3', 'n_b = 2
n_j = (n_a + 1)*(n_b + 1)
n_e = n_a*n_b
x_j = vector(n_j)
y_j = vector(n_j)
k = 0
#for i = 0 : n_a
	#for j = 0 : n_b
		k = k + 1
		x_j.k = i*2
		y_j.k = j*1.5
	#loop
#loop
e_j = matrix(n_e; 4)
k = 0
#for i = 1 : n_a
	#for j = 1 : n_b
		k = k + 1
		j_1 = (i - 1)*(n_b + 1) + j
		e_j.(k; 1) = j_1
		e_j.(k; 2) = j_1 + n_b + 1
		e_j.(k; 3) = j_1 + n_b + 2
		e_j.(k; 4) = j_1 + 1
	#loop
#loop
'Soportes: nodos del borde
s_j = vector(2*(n_a + n_b))
k = 0
#for i = 1 : n_a + 1
	k = k + 1
	s_j.k = (i - 1)*(n_b + 1) + 1
#loop
#for i = 1 : n_a + 1
	k = k + 1
	s_j.k = i*(n_b + 1)
#loop
'Valores simulados (parabolico)
W = vector(n_j)
#for i = 1 : n_j
	x = x_j.i/(n_a*2)
	y = y_j.i/(n_b*1.5)
	W.i = -sin(π*x)*sin(π*y)*5
#loop
#show
'Nodos:
x_j
y_j
'Conectividad:
transp(e_j)
'Desplazamientos:
W
$Fem2D{x_j; y_j; e_j; W @ w=650 & h=400 & palette=jet & title=Desplazamientos & supports=s_j}
'<h3>Grafica 2D</h3>
#hide
n_pts = 30
x_d = vector(n_pts)
y_sin = vector(n_pts)
y_cos = vector(n_pts)
#for i = 1 : n_pts
	x_d.i = (i - 1)*2*π/(n_pts - 1)
	y_sin.i = sin(x_d.i)
	y_cos.i = cos(x_d.i)
#loop
#show
$Chart{x_d; y_sin; x_d; y_cos @ type=line & title=Trigonometricas & xlabel=x (rad) & ylabel=f(x) & label1=sin & label2=cos & w=650}
