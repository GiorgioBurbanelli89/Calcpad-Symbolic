"Test #python bloque multilínea

"1. Python básico
#python
import math
print(f"pi = {math.pi:.6f}")
print(f"e = {math.e:.6f}")
print(f"sqrt(2) = {math.sqrt(2):.6f}")
#end python

"2. SymPy simbólico
#python
from sympy import symbols, diff, integrate, solve, sin, cos, pi, latex
x = symbols('x')
print("diff(x^3) =", diff(x**3, x))
print("integrate(sin(x)) =", integrate(sin(x), x))
print("solve(x^2-4) =", solve(x**2 - 4, x))
print("Taylor sin(x) =", sin(x).series(x, 0, 6))
#end python

"3. NumPy matrices
#python
import numpy as np
K = np.array([[4, -2], [-2, 4]])
eigenvalues = np.linalg.eigvals(K)
det = np.linalg.det(K)
print(f"K = {K.tolist()}")
print(f"eigenvalues = {eigenvalues.tolist()}")
print(f"det(K) = {det:.1f}")
#end python

"4. OpenSeesPy — Cantilever beam
#python
import openseespy.opensees as ops
ops.wipe()
ops.model('basic', '-ndm', 2, '-ndf', 3)
ops.node(1, 0.0, 0.0)
ops.node(2, 5.0, 0.0)
ops.fix(1, 1, 1, 1)
ops.uniaxialMaterial('Elastic', 1, 200000.0)
A = 0.01
I = 8.333e-6
ops.section('Elastic', 1, 200000.0, A, I)
ops.geomTransf('Linear', 1)
ops.element('elasticBeamColumn', 1, 1, 2, A, 200000.0, I, 1)
ops.timeSeries('Linear', 1)
ops.pattern('Plain', 1, 1)
ops.load(2, 0.0, -10.0, 0.0)
ops.system('BandSPD')
ops.numberer('RCM')
ops.constraints('Plain')
ops.integrator('LoadControl', 1.0)
ops.algorithm('Linear')
ops.analysis('Static')
ops.analyze(1)
ux = ops.nodeDisp(2, 1)
uy = ops.nodeDisp(2, 2)
rz = ops.nodeDisp(2, 3)
print(f"Node 2 displacements:")
print(f"  ux = {ux:.6e}")
print(f"  uy = {uy:.6e}")
print(f"  rz = {rz:.6e}")
# Analytical: PL³/3EI
P = 10.0
L = 5.0
E = 200000.0
uy_exact = -P*L**3/(3*E*I)
print(f"  uy_exact = {uy_exact:.6e}")
print(f"  error = {abs(uy-uy_exact)/abs(uy_exact)*100:.4f}%")
# Export to Calcpad
print(f"CALCPAD:uy={uy:.10e}")
ops.wipe()
#end python

"5. Resultado de OpenSeesPy en Calcpad
uy
